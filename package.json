{
	"name": "@byearlybird/crdt",
	"version": "0.0.1",
	"files": [
		"dist"
	],
	"type": "module",
	"main": "./dist/index.js",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"scripts": {
		"build": "bun run build.ts",
		"dev": "bun build src/index.ts --outdir dist --format esm --sourcemap=linked --target browser --watch",
		"test": "bun test",
		"test:watch": "bun test --watch",
		"check": "bunx --bun @biomejs/biome check --write",
		"typecheck": "tsc --noEmit",
		"prepublishOnly": "bun run build"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.6",
		"@types/bun": "^1.3.7",
		"typescript": "^5.7.3"
	},
	"peerDependencies": {
		"typescript": "^5"
	}
}
